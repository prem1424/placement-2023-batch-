import java.util.*;

class Customer {
    int roomNo;
    String name;

    Customer(int roomNo, String name) {
        this.roomNo = roomNo;
        this.name = name;
    }
}

public class Main {

    static ArrayList<Customer> list = new ArrayList<>();

    // Check-in
    public static void addCustomer(int roomNo, String name) {
        list.add(new Customer(roomNo, name));
        System.out.println("Customer added successfully!");
    }

    // View all customers
    public static void display() {
        if (list.isEmpty()) {
            System.out.println("No customers.");
            return;
        }

        for (Customer c : list) {
            System.out.println("Room: " + c.roomNo + " Name: " + c.name);
        }
    }

    // Checkout
    public static void removeCustomer(int roomNo) {
        for (int i = 0; i < list.size(); i++) {
            if (list.get(i).roomNo == roomNo) {
                list.remove(i);
                System.out.println("Customer removed!");
                return;
            }
        }
        System.out.println("Room not found!");
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.println("\n1. Check-in");
            System.out.println("2. View Customers");
            System.out.println("3. Checkout");
            System.out.println("4. Exit");

            System.out.print("Enter choice: ");
            int ch = sc.nextInt();
            sc.nextLine(); // clear buffer

            switch (ch) {
                case 1:
                    System.out.print("Enter Room No: ");
                    int room = sc.nextInt();
                    sc.nextLine();

                    System.out.print("Enter Name: ");
                    String name = sc.nextLine();

                    addCustomer(room, name);
                    break;

                case 2:
                    display();
                    break;

                case 3:
                    System.out.print("Enter Room No to checkout: ");
                    int r = sc.nextInt();
                    removeCustomer(r);
                    break;

                case 4:
                    System.out.println("Thank You!");
                    return;

                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
