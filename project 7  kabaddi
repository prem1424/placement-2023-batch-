import java.util.*;

public class KabaddiManagement {

    static String[] playerName = new String[5];
    static int[] raidPoints = new int[5];
    static int[] tacklePoints = new int[5];
    static int count = 0;

    // Add Player
    static void addPlayer(String name, int raid, int tackle) {
        if (count < playerName.length) {
            playerName[count] = name;
            raidPoints[count] = raid;
            tacklePoints[count] = tackle;
            count++;
            System.out.println("Player added successfully.");
        } else {
            System.out.println("Team is full!");
        }
    }

    // View Players
    static void viewPlayers() {
        System.out.println("\n--- Kabaddi Player List ---");
        for (int i = 0; i < count; i++) {
            System.out.println("Name: " + playerName[i] +
                               ", Raid Points: " + raidPoints[i] +
                               ", Tackle Points: " + tacklePoints[i]);
        }
    }

    // Search Player
    static void searchPlayer(String name) {
        for (int i = 0; i < count; i++) {
            if (playerName[i].equals(name)) {
                System.out.println("Found: " + playerName[i] +
                                   ", Raid: " + raidPoints[i] +
                                   ", Tackle: " + tacklePoints[i]);
                return;
            }
        }
        System.out.println("Player not found!");
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice, raid, tackle;
        String name;

        do {
            System.out.println("\n--- Kabaddi Management System ---");
            System.out.println("1. Add Player");
            System.out.println("2. View Players");
            System.out.println("3. Search Player");
            System.out.println("4. Exit");
            System.out.print("Enter your choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Enter player name: ");
                    name = sc.next();
                    System.out.print("Enter raid points: ");
                    raid = sc.nextInt();
                    System.out.print("Enter tackle points: ");
                    tackle = sc.nextInt();
                    addPlayer(name, raid, tackle);
                    break;

                case 2:
                    viewPlayers();
                    break;

                case 3:
                    System.out.print("Enter player name to search: ");
                    name = sc.next();
                    searchPlayer(name);
                    break;

                case 4:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 4);

        sc.close();
    }
}
